# ============================================================
#  ThreatMatrix — Environment Variables
#  Copy to .env (same dir as docker-compose.yml) and edit.
# ============================================================

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
#
# HTTP integration test (Phase 1):
#   CORS_ORIGINS=*                                         # dev wildcard
#   CORS_ORIGINS=http://localhost:3000                     # tighten when stable
#
# HTTPS integration test (Phase 2):
#   CORS_ORIGINS=https://localhost                         # via Caddy
#
# Production:
#   CORS_ORIGINS=https://threatmatrix.web.app,https://threatmatrix.example.com
CORS_ORIGINS=*

# ─── Authentication ──────────────────────────────────────────────────────────
# 0 = WebSocket and HTTP endpoints accept anonymous (dev mode).
# 1 = WebSocket requires ?token=<jwt>; HTTP requires Authorization header.
#     Requires the verify_token_stub() in app/main.py to be implemented
#     against your IdP (Auth0 / Supabase / etc.).
AUTH_REQUIRED=0

# ─── Auth0 (only when AUTH_REQUIRED=1) ───────────────────────────────────────
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_AUDIENCE=https://api.threatmatrix.io

# ─── Model paths (rarely changed) ────────────────────────────────────────────
# BINARY_DIR=/app/models/binary
# MULTICLASS_DIR=/app/models/multiclass
# PHASE3_DIR=/app/models/anomaly
# METRICS_FILE=/app/models/metrics.json

# ─── Buffer ──────────────────────────────────────────────────────────────────
# FLOW_BUFFER_SIZE=10000
