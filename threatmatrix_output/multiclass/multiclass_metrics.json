{
    "phase": "multiclass",
    "scope": "Severity Classification: Reconnaissance / Credential_Abuse / Active_Exploitation",
    "feature_schema": "behaviour_based_14_protocol_agnostic",
    "feature_changes": {
        "removed_features": [
            "fwd_header_size_tot",
            "bwd_header_size_tot"
        ],
        "removed_reason": "TLS handshake adds ~5-20 bytes to header overhead, creating a systematic HTTP vs HTTPS difference. Protocol fingerprint, not behaviour.",
        "smote_strategy": {
            "old": "TARGET_CLASS_COUNT = 200_000 (fixed for all classes)",
            "new": "match_largest_real (only up-sample minorities to max real count)",
            "target_per_class_used": 1208787
        },
        "recon_cap": {
            "old": 200000,
            "new": 100000,
            "reason": "previously cap of 200K still over-balanced relative to other classes. now cap of 100K maintains balance without artificially trivialising the problem."
        },
        "coverage_penalty": {
            "old": 0.7,
            "new": 0.5
        },
        "zero_var_drop_post_split": [],
        "optuna_trials": {
            "rf": 15,
            "xgb": 25,
            "old_v2": {
                "rf": 30,
                "xgb": 50
            }
        },
        "imputer_leakage": "previously fitted SimpleImputer before train/test split. now fits on train only, transforms test separately."
    },
    "n_features": 14,
    "feature_names": [
        "flow_duration",
        "fwd_pkts_tot",
        "bwd_pkts_tot",
        "fwd_data_pkts_tot",
